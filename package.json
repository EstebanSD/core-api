{
  "name": "core-api",
  "version": "0.1.0",
  "description": "Modular and scalable API built with NestJS and MongoDB, designed to support a portfolio and other personal projects.",
  "author": "Esteban Salvay Dilena",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": "^22.0.0",
    "npm": ">=10"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "NODE_ENV=production node dist/main.js",
    "start:dev": "NODE_ENV=development nest start --watch",
    "start:debug": "NODE_ENV=development nest start --debug --watch",
    "dev": "npm run start:dev",
    "prod": "npm run build && npm run start",
    "test": "NODE_ENV=test jest --selectProjects unit",
    "test:watch": "NODE_ENV=test jest --selectProjects unit --watch",
    "test:cov": "NODE_ENV=test jest --selectProjects unit --coverage",
    "test:integration": "NODE_ENV=test jest --selectProjects integration",
    "test:integration:watch": "NODE_ENV=test jest --selectProjects integration --watch",
    "test:e2e": "NODE_ENV=test jest --selectProjects e2e",
    "test:e2e:watch": "NODE_ENV=test jest --selectProjects e2e --watch",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/mongoose": "^11.0.3",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/serve-static": "^5.0.3",
    "@nestjs/throttler": "^6.4.0",
    "bcrypt": "^6.0.0",
    "chalk": "^4.1.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cloudinary": "^2.6.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.2.6",
    "joi": "^17.13.3",
    "jsdom": "^26.1.0",
    "mongoose": "^8.15.1",
    "openai": "^6.25.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "serve-static": "^2.2.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/jsdom": "^21.1.7",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.7",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "overrides": {
    "multer": "^2.0.1"
  }
}
